# Host-side port.
SEARCHX_PORT=7310

# Optional Docker Hub mirror. Useful on hosts where Docker Hub is slow.
# NODE_IMAGE=docker.m.daocloud.io/library/node:22-bookworm-slim
# Optional package mirrors. Useful for deployments where Debian/PyPI/npm are slow.
# APT_MIRROR=https://mirrors.tuna.tsinghua.edu.cn
# PIP_INDEX_URL=https://mirrors.aliyun.com/pypi/simple/
# NPM_REGISTRY=https://registry.npmmirror.com
# NPM_BUILD_FROM_SOURCE=1
# Optional local runtime base image. Leave unset for normal deployments.
# RUNTIME_IMAGE=file-rag-nas:v2.0.0_20260511
# BUILD_APT_PACKAGES=
# RUNTIME_APT_PACKAGES=python3-pip python3.12-venv tini poppler-utils ffmpeg tesseract-ocr tesseract-ocr-chi-sim

# Host-side persistent state directory. QMD models, catalog, Markdown mirrors,
# previews, and SQLite index are stored here.
SEARCHX_STATE_DIR=./searchx-data

# Host-side read-only source files directory. In the app, add /data as a root.
SEARCHX_FILES_DIR=./sample-data

# Keep CPU mode by default. This is the safest setting for Ubuntu servers and
# Intel Ultra laptops/mini PCs without extra llama.cpp GPU runtime setup.
QMD_FORCE_CPU=1
QMD_LLAMA_GPU=false

# Optional: better multilingual/CJK embedding recall. Re-index with force after
# changing embedding models.
# QMD_EMBED_MODEL=hf:Qwen/Qwen3-Embedding-0.6B-GGUF/Qwen3-Embedding-0.6B-Q8_0.gguf
# QMD_RERANK_MODEL=hf:...
# QMD_GENERATE_MODEL=hf:...

# Sync/search behavior.
SEARCHX_QMD_EMBED_ON_INGEST=1
SEARCHX_QMD_CHUNK_STRATEGY=auto
SEARCHX_QMD_UPDATE_TIMEOUT_MS=120000
SEARCHX_QMD_EMBED_TIMEOUT_MS=1800000
SEARCHX_DEEP_SEARCH_TIMEOUT_MS=30000
SEARCHX_DEEP_SEARCH_CANDIDATE_LIMIT=16

# Set to 1 only for trusted LAN deployments if API clients should stream raw
# source files through /api/assets/:id/raw. Preview and download endpoints do
# not require this.
SEARCHX_ALLOW_RAW_FILE_ACCESS=0

# Optional MarkItDown VLM/LLM provider.
# OPENAI_BASE_URL=http://host.docker.internal:11434/v1
# OPENAI_API_KEY=local
# SEARCHX_LLM_MODEL=qwen2.5vl:7b
# SEARCHX_MARKITDOWN_USE_LLM=1

# Optional Docling PDF fallback. Also build the image with INSTALL_DOCLING=1.
INSTALL_DOCLING=0
SEARCHX_DOCLING_ENABLED=0
DOCLING_DEVICE=cpu
DOCLING_NUM_THREADS=4
