# API server
SEARCHX_HOST=127.0.0.1
SEARCHX_PORT=7310
SEARCHX_DATA_DIR=.searchx
XDG_CACHE_HOME=.searchx/cache

# Python converter
SEARCHX_PYTHON=python
SEARCHX_MARKITDOWN_PLUGINS=1
SEARCHX_MARKITDOWN_ARCHIVES=1
SEARCHX_MARKITDOWN_MEDIA=1

# Optional OpenAI-compatible provider for MarkItDown.
# Point OPENAI_BASE_URL at a local OpenAI-compatible server for local-first use.
# When OPENAI_BASE_URL and SEARCHX_LLM_MODEL are set, SearchX lets MarkItDown
# call the provider automatically. Set SEARCHX_MARKITDOWN_USE_LLM=0 to disable it.
# OPENAI_BASE_URL=http://127.0.0.1:11434/v1
# OPENAI_API_KEY=local
# SEARCHX_LLM_MODEL=qwen2.5vl:7b
# SEARCHX_MARKITDOWN_USE_LLM=1
SEARCHX_LLM_TIMEOUT_SEC=60
SEARCHX_CONVERTER_TIMEOUT_MS=120000
# Disabled by default so API clients cannot stream arbitrary original files.
SEARCHX_ALLOW_RAW_FILE_ACCESS=0

# QMD
SEARCHX_QMD_COLLECTION=searchx
SEARCHX_QMD_EMBED_ON_INGEST=1
SEARCHX_QMD_CHUNK_STRATEGY=auto
SEARCHX_DEEP_SEARCH_TIMEOUT_MS=30000
SEARCHX_DEEP_SEARCH_CANDIDATE_LIMIT=16
# Recommended for multilingual/CJK corpora:
# QMD_EMBED_MODEL=hf:Qwen/Qwen3-Embedding-0.6B-GGUF/Qwen3-Embedding-0.6B-Q8_0.gguf
